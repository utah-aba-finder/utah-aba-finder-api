<!DOCTYPE html>
<html>
<head>
  <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
</head>
<body>
  <h1>New Provider Registration</h1>
  
  <h2><%= @registration.provider_name %></h2>
  
  <p><strong>Practice / listing email:</strong> <%= @registration.email %></p>
  <% if @registration.try(:applicant_email).present? %>
    <p><strong>Applicant (notifications and login):</strong> <%= @registration.try(:applicant_email) %></p>
  <% else %>
    <p><em>No separate applicant email; notifications use the practice email above.</em></p>
  <% end %>
  <p><strong>Category:</strong> <%= @registration.category %></p>
  <p><strong>Status:</strong> <%= @registration.status %></p>
  <p><strong>Submitted:</strong> <%= @registration.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
  
  <h3>Submitted Information:</h3>
  <% (@registration.submitted_data || {}).each do |key, value| %>
    <p><strong><%= key.to_s.humanize %>:</strong> <%= value %></p>
  <% end %>
  
  <p>
    <a href="<%= @registration_review_url %>">Review this registration</a>
  </p>

</body>
</html> 